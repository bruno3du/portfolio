{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "prebuild": "pnpm gen",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "gen:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "gen:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "gen": "pnpm gen:importmap & pnpm gen:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation payload run src/scripts/seed.ts",
    "seed:force": "cross-env NODE_OPTIONS=--no-deprecation SEED_MODE=upsert payload run src/scripts/seed.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next && rm -rf node_modules && pnpm i"
  },
  "dependencies": {
    "@payloadcms/db-mongodb": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "graphql": "^16.13.2",
    "next": "^16.2.4",
    "cross-env": "^10.1.0",
    "payload": "^3.84.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.2.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3"
  }
}
